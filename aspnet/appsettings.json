{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "server=mysql;port=3306;database=app_db;user=app_user;password=secret",
    "DefaultConnectionByLocalhost": "server=localhost;database=demoapi_db;user=root;password="  
  },
  "Jwt": {
    "Key": "this_is_super_secret_key_1234567",
    "Issuer": "DemoAPI"
  },
  "Redis": {
    "ConnectionString": "redis:6379",
    "ConnectionStringByLocalhost": "localhost:6379"
  }
}
